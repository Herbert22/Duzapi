      "position_x": 500, "position_y": 1220
    },
    {
      "id": "10000000-0000-0000-0000-000000000027",
      "type": "send_text",
      "data": {"text": "Perfeito! Vou agendar sua videochamada com o Dr. Igor no período da {horario_preferido}. \ud83d\udcc5\n\nEm breve entraremos em contato para confirmar o dia e horário exatos.\n\nQualquer dúvida, estou à disposição! \ud83d\ude0a"},
