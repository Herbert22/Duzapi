# ==========================================================================
# DuzAPI — WhatsApp Automation Platform
# Copy this file to .env and fill in ALL required values before deploying.
# ==========================================================================

# --------------------------------------------------------------------------
# REQUIRED — must change before production
# --------------------------------------------------------------------------

# Min 32 random characters. Generate: openssl rand -hex 32
SECRET_KEY=CHANGE_ME_min_32_chars

# Shared token between backend and bridge. Generate: openssl rand -hex 24
BRIDGE_AUTH_TOKEN=CHANGE_ME_bridge_token

# HMAC secret for webhook signatures. Generate: openssl rand -hex 32
WEBHOOK_SECRET=CHANGE_ME_webhook_secret

# Fernet key for encrypting tenant API keys.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=CHANGE_ME_fernet_key

# Redis password. Generate: openssl rand -hex 24
REDIS_PASSWORD=CHANGE_ME_redis_password

# PostgreSQL credentials
POSTGRES_USER=whatsapp
POSTGRES_PASSWORD=CHANGE_ME_postgres_password
POSTGRES_DB=whatsapp_automation

# MongoDB credentials
MONGO_USER=whatsapp
MONGO_PASSWORD=CHANGE_ME_mongo_password
MONGODB_DB=whatsapp_logs

# --------------------------------------------------------------------------
# NEXT.JS ADMIN PANEL
# --------------------------------------------------------------------------

# Public URL of the admin panel (for NextAuth callbacks)
# Example: https://admin.yourdomain.com
NEXTAUTH_URL=http://localhost

# NextAuth secret (defaults to SECRET_KEY if not set)
NEXTAUTH_SECRET=

# Asaas payment gateway (optional)
ASAAS_API_KEY=
ASAAS_WEBHOOK_TOKEN=

# --------------------------------------------------------------------------
# AI PROVIDERS
# --------------------------------------------------------------------------

# Default AI provider: "gemini" or "openai"
AI_PROVIDER=gemini

# Google Gemini API key (default fallback for tenants without their own key)
GOOGLE_API_KEY=

# OpenAI API key (default fallback; also used for Whisper transcription)
OPENAI_API_KEY=

# --------------------------------------------------------------------------
# OPTIONAL — sensible defaults provided
# --------------------------------------------------------------------------

# Application
APP_NAME=WhatsApp Automation API
APP_VERSION=1.0.0
DEBUG=false
API_PREFIX=/api/v1

# Logging — "json" for structured logs, "text" for human-readable
LOG_LEVEL=info
LOG_FORMAT=json

# CORS — comma-separated list of allowed frontend origins
# In production with nginx, the admin panel is on the same origin
CORS_ORIGINS_STR=http://localhost

# Message log TTL in days (MongoDB TTL index)
MESSAGE_LOG_TTL_DAYS=90

# Node environment (for bridge container)
NODE_ENV=production

# WPPConnect debug mode
WPP_DEBUG=false
