# Server Configuration
PORT=3000
NODE_ENV=development

# Backend Webhook URL
BACKEND_WEBHOOK_URL=http://backend:8000/api/v1/webhooks/whatsapp

# Session Storage
SESSIONS_PATH=./sessions
TENANT_MAPPING_PATH=./tenant_mapping.json

# Audio Configuration
AUDIO_DOWNLOAD_PATH=./downloads/audio
AUDIO_BASE_URL=http://whatsapp_bridge:3000/audio

# WPPConnect Configuration
WPP_HEADLESS=true
WPP_USE_CHROME=false
WPP_DEBUG=false
WPP_LOG_QR=true

# Logging
LOG_LEVEL=info
